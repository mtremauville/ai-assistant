<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<% end %>

<div class="page-wrapper">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <%= button_to "Nouvelle session", chats_path, method: :post, class: "new-chat-btn", form: { data: { turbo: false } } %>
    <div class="sidebar-title">Historique</div>
    <% @chats.each do |chat| %>
      <%= link_to chat.title, chat_path(chat), class: "sidebar-item#{' active' if chat == @chat}" %>
    <% end %>
    <div class="sidebar-spacer"></div>
    <%= link_to trainings_path, class: "sidebar-training-btn" do %>
      <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Training Library
    <% end %>
  </aside>

  <!-- MAIN -->
  <main class="chat-main">

    <!-- MESSAGES -->
    <div class="messages-wrap" id="messagesWrap">
      <div class="messages-inner" id="messages-inner">

        <div>
          <div class="chat-title"><%= @chat.title %></div>
        </div>

        <% @chat.messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>

      </div>
    </div>

    <!-- INPUT -->
    <div class="input-section" id="new_message_container">
      <%= render "ask_form", chat: @chat, message: @message %>
    </div>

  </main>
</div>

<% content_for :scripts do %>
  <script>
    const messagesWrap = document.getElementById('messagesWrap');
    if (messagesWrap) {
      messagesWrap.scrollTop = messagesWrap.scrollHeight;
      new MutationObserver(() => {
        messagesWrap.scrollTop = messagesWrap.scrollHeight;
      }).observe(messagesWrap, { childList: true, subtree: true });
    }
  </script>
<% end %>
