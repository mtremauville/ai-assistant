<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<% end %>

<div class="page-wrapper">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-title">History</div>
    <% @chats.each do |chat| %>
      <div class="sidebar-item-row" id="sidebar-chat-wrap-<%= chat.id %>">
        <%= link_to chat_path(chat), class: "sidebar-item#{' active' if chat == @chat}" do %>
          <span id="sidebar-chat-title-<%= chat.id %>"><%= chat.title %></span>
        <% end %>
        <%= button_to chat_path(chat), method: :delete, class: "sidebar-delete-btn",
              form: { data: { turbo: true } } do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        <% end %>
      </div>
    <% end %>
    <div class="sidebar-spacer"></div>
    <%= button_to "New Session", chats_path, method: :post, class: "new-chat-btn", form: { data: { turbo: false } } %>
  </aside>

  <!-- MAIN -->
  <main class="chat-main<%= ' chat-empty' if @chat.messages.empty? %>" id="chatMain">

    <!-- MESSAGES -->
    <div class="messages-wrap" id="messagesWrap">
      <div class="messages-inner" id="messages-inner">

        <% unless @chat.messages.empty? %>
          <div>
            <div class="chat-title" id="chat-main-title"><%= @chat.title %></div>
          </div>
        <% end %>

        <% @chat.messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>

      </div>
    </div>

    <!-- BOTTOM GROUP: welcome + input (animated together) -->
    <div class="chat-bottom-group" id="chatBottomGroup">

      <% if @chat.messages.empty? %>
        <div class="welcome-wrap" id="welcomeWrap">
          <div class="welcome-eyebrow">Maestro — Your Padel Coach</div>
          <div class="welcome-greeting">
            Hey,&nbsp;<span class="welcome-name"><%= current_user.email.split('@').first.capitalize %></span>
          </div>
          <div class="welcome-sub" id="welcomeSub" data-text="Describe your ideal session and I'll build the perfect training."></div>
        </div>
      <% end %>

      <div class="input-section" id="new_message_container">
        <%= render "ask_form", chat: @chat, message: @message, chips: @chips %>
      </div>

    </div>

  </main>
</div>

<!-- Full-page save loader overlay -->
<div class="save-loader-overlay" id="saveLoaderOverlay">
  <div class="tennis-ball-wrap">
    <div class="tennis-ball"></div>
  </div>
  <p class="save-loader-label">Saving your session…</p>
</div>

<% content_for :scripts do %>
  <script>
    const messagesWrap = document.getElementById('messagesWrap');
    if (messagesWrap) {
      messagesWrap.scrollTop = messagesWrap.scrollHeight;
      new MutationObserver(() => {
        messagesWrap.scrollTop = messagesWrap.scrollHeight;
      }).observe(messagesWrap, { childList: true, subtree: true });
    }

    // FLIP animation: slide input from center to bottom on first submit
    document.addEventListener('turbo:submit-start', function(e) {
      const chatMain    = document.getElementById('chatMain');
      const bottomGroup = document.getElementById('chatBottomGroup');
      const welcomeWrap = document.getElementById('welcomeWrap');

      // Always clear the input on submit
      const chatInput = document.getElementById('chatInput');
      if (chatInput) chatInput.value = '';

      // Inject loading bubble while waiting for AI response
      const messagesInner = document.getElementById('messages-inner');
      if (messagesInner) {
        const loaderEl = document.createElement('div');
        loaderEl.id = 'loading-bubble';
        loaderEl.className = 'bubble-loader-wrap';
        loaderEl.innerHTML = '<div class="bubble-loader"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>';
        messagesInner.appendChild(loaderEl);
      }

      if (!chatMain || !chatMain.classList.contains('chat-empty')) return;

      // Record current (centered) position
      const first = bottomGroup.getBoundingClientRect();

      // Remove class → layout jumps to final (bottom) position
      chatMain.classList.remove('chat-empty');
      void bottomGroup.offsetHeight; // force reflow

      // Record final (bottom) position
      const last = bottomGroup.getBoundingClientRect();
      const dy = first.top - last.top;

      // Start from original position
      bottomGroup.style.transition = 'none';
      bottomGroup.style.transform  = `translateY(${dy}px)`;

      // Animate to final position
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          bottomGroup.style.transition = 'transform 0.65s cubic-bezier(0.16, 1, 0.3, 1)';
          bottomGroup.style.transform  = '';
        });
      });

      // Fade out welcome message
      if (welcomeWrap) {
        welcomeWrap.style.transition = 'opacity 0.25s ease';
        welcomeWrap.style.opacity    = '0';
        setTimeout(() => welcomeWrap.remove(), 300);
      }
    });

    // Show full-page loader when saving a training session
    document.addEventListener('click', function(e) {
      if (e.target.closest('.save-training-inline-btn')) {
        document.getElementById('saveLoaderOverlay').classList.add('visible');
      }
    });

    // Typewriter effect for welcome subtitle — runs on every navigation
    function initTypewriter() {
      const welcomeSub = document.getElementById('welcomeSub');
      if (!welcomeSub || welcomeSub.dataset.twInit) return;
      welcomeSub.dataset.twInit = '1';

      const text   = welcomeSub.dataset.text;
      const cursor = document.createElement('span');
      cursor.className   = 'tw-cursor';
      cursor.textContent = '|';
      welcomeSub.appendChild(cursor);

      let i = 0;
      setTimeout(() => {
        const timer = setInterval(() => {
          if (i < text.length) {
            welcomeSub.insertBefore(document.createTextNode(text[i]), cursor);
            i++;
          } else {
            clearInterval(timer);
            setTimeout(() => {
              cursor.style.transition = 'opacity 0.4s';
              cursor.style.opacity = '0';
              setTimeout(() => cursor.remove(), 400);
            }, 800);
          }
        }, 32);
      }, 700);
    }

    initTypewriter();
    document.addEventListener('turbo:load', initTypewriter);
  </script>
<% end %>
