<% content_for(:hide_navbar, true) %>

<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<% end %>

<nav class="chat-nav">
  <div class="nav-brand">Padel Maestro</div>
  <div class="nav-links">
    <a href="#">Chatbot</a>
    <div class="nav-sep"></div>
    <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete } %>
  </div>
</nav>

<div class="page-wrapper">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <%= button_to "Nouvelle session", chats_path, method: :post, class: "new-chat-btn", form: { data: { turbo: false } } %>
    <div class="sidebar-title">Historique</div>
    <% @chats.each do |chat| %>
      <%= link_to chat.title, chat_path(chat), class: "sidebar-item#{' active' if chat == @chat}" %>
    <% end %>
    <div class="sidebar-spacer"></div>
    <%= link_to generate_training_chat_path(@chat), data: { turbo_method: :post }, class: "save-training-btn" do %>
      <svg viewBox="0 0 24 24"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
      Save Training
    <% end %>
    <%= link_to trainings_path, class: "sidebar-training-btn" do %>
      <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Training Library
    <% end %>
  </aside>

  <!-- MAIN -->
  <main class="chat-main">

    <!-- MESSAGES -->
    <div class="messages-wrap" id="messagesWrap">
      <div class="messages-inner">

        <div>
          <div class="page-heading">Chats › show</div>
          <div class="chat-title"><%= @chat.title %></div>
        </div>

        <% @chat.messages.each do |message| %>
          <% if message.role == "user" %>
            <div class="msg-row user">
              <div class="bubble-user">
                <%= simple_format(message.content) %>
              </div>
            </div>
          <% elsif message.role == "assistant" %>
            <div class="msg-row coach">
              <div class="bubble-coach">
                <div class="coach-tag">
                  <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  Le Conseil du Maestro
                </div>
                <%= simple_format(message.content) %>
              </div>
            </div>
          <% end %>
        <% end %>

      </div>
    </div>

    <!-- INPUT -->
    <div class="input-section" id="new_message_container">
      <%= render "ask_form", chat: @chat, message: @message %>
    </div>

  </main>
</div>

<% content_for :scripts do %>
  <script>
    function scrollToBottom() {
      const w = document.getElementById('messagesWrap');
      if (w) w.scrollTop = w.scrollHeight;
    }
    scrollToBottom();
  </script>
<% end %>
