<div class="profile-bg">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7 col-xl-6">
        <div class="tl-detail-inner profile-inner">

          <%# ── Header : avatar + username + crayon ───────────────────────── %>
          <div class="d-flex align-items-center gap-3 mb-4">
            <div class="profile-avatar-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M 4.5 7 C 9.5 7 9.5 17 4.5 17"/>
                <path d="M 19.5 7 C 14.5 7 14.5 17 19.5 17"/>
              </svg>
            </div>
            <h1 class="tl-detail-title mb-0"><%= current_user.username %></h1>
            <%= link_to edit_user_registration_path, class: "profile-edit-btn", title: "Edit profile" do %>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            <% end %>
          </div>

          <%# ── Row 1 : height + weight + age + gender ───────────────────── %>
          <div class="profile-info-row mb-2">
            <div class="tl-info-box">
              <div class="tl-info-label">Height</div>
              <div class="tl-info-value"><%= current_user.height %></div>
            </div>
            <div class="tl-info-box">
              <div class="tl-info-label">Weight</div>
              <div class="tl-info-value"><%= current_user.weight %></div>
            </div>
            <div class="tl-info-box">
              <div class="tl-info-label">Age</div>
              <div class="tl-info-value"><%= current_user.age %></div>
            </div>
            <div class="tl-info-box">
              <div class="tl-info-label">Gender</div>
              <div class="tl-info-value profile-gender profile-gender--<%= current_user.gender %>">
                <%= current_user.gender&.capitalize %>
              </div>
            </div>
          </div>

          <%# ── Row 2 : email + password ───────────────────────────────────── %>
          <div class="profile-contact-row mb-2">
            <div class="tl-info-box">
              <div class="tl-info-label">Email</div>
              <div class="tl-info-value profile-info-truncate"><%= current_user.email %></div>
            </div>
            <div class="tl-info-box">
              <div class="tl-info-label">Password</div>
              <div class="tl-info-value">••••••••</div>
            </div>
          </div>

          <%# ── Row 3 : padel level + hand position ────────────────────────── %>
          <% hand = current_user.hand_position&.downcase %>
          <div class="profile-sections-row">
            <div class="tl-section">
              <div class="tl-section-title">Padel Level</div>
              <div class="profile-level">
                <div class="profile-level__header">
                  <span></span>
                  <span class="profile-level__number"><%= current_user.padel_level %> / 7</span>
                </div>
                <div class="profile-level__bar">
                  <% 7.times do |i| %>
                    <div class="profile-level__segment <%= i < current_user.padel_level.to_i ? 'active' : '' %>"></div>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="tl-section">
              <div class="tl-section-title">Position</div>
              <div class="profile-hand">
                <div class="profile-hand__option <%= hand == 'left' || hand == 'both' ? 'active' : '' %>">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 11V6a2 2 0 0 0-4 0v5M14 10V4a2 2 0 0 0-4 0v6M10 10V5a2 2 0 0 0-4 0v9M6 10a2 2 0 0 0-4 0v4a8 8 0 0 0 16 0v-5a2 2 0 0 0-4 0"/>
                  </svg>
                  <span>Left</span>
                </div>
                <div class="profile-hand__option <%= hand == 'right' || hand == 'both' ? 'active' : '' %>">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="transform: scaleX(-1)">
                    <path d="M18 11V6a2 2 0 0 0-4 0v5M14 10V4a2 2 0 0 0-4 0v6M10 10V5a2 2 0 0 0-4 0v9M6 10a2 2 0 0 0-4 0v4a8 8 0 0 0 16 0v-5a2 2 0 0 0-4 0"/>
                  </svg>
                  <span>Right</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
