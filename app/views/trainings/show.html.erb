<%= turbo_frame_tag "training-detail" do %>
  <div class="tl-detail-inner">

    <%# ── Header ─────────────────────────────────────────────────── %>
    <button class="tl-detail-back"
            data-action="click->training-library#close">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Fermer
    </button>

    <h1 class="tl-detail-title"><%= @training.name.presence || "Séance #{@training.training_type.capitalize}" %></h1>

    <div class="tl-title-meta">
      <span class="tl-detail-badge badge-type"><%= @training.training_type %></span>
      <div class="tl-stars" aria-label="Note : <%= @training.feedback_rating.present? ? "#{(@training.feedback_rating.to_f / 10 * 3).round} étoiles sur 3" : "non notée" %>">
        <% stars_filled = @training.feedback_rating.present? ? [(@training.feedback_rating.to_f / 10 * 3).round, 3].min : 0 %>
        <% 3.times do |i| %>
          <svg class="tl-star <%= i < stars_filled ? 'active' : '' %>" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        <% end %>
      </div>
    </div>

    <%# ── Image ───────────────────────────────────────────────────── %>
    <div class="tl-detail-image">
      <%# <% image_src = @training.image_url.presence ||
           "https://source.unsplash.com/featured/800x450/?padel,sport&sig=#{@training.id}" %>
      <% image_src = @training.image_url.presence || training_banner(@training) %>
      <%= image_tag image_src,
            alt: @training.name,
            style: "width:100%; height:100%; object-fit:cover; filter:grayscale(20%) brightness(0.85);",
            onerror: "this.style.display='none';this.nextElementSibling.style.display='flex';" %>
      <div class="tl-img-placeholder" style="display:none;">
        <i class="fa-regular fa-image fa-2x"></i>
        <span>Exercice Padel</span>
      </div>
    </div>

    <%# ── Info boxes ─────────────────────────────────────────────── %>
    <div class="tl-info-row">
      <div class="tl-info-box">
        <div class="tl-info-label">Type</div>
        <div class="tl-info-value"><%= @training.training_type.capitalize %></div>
      </div>
      <div class="tl-info-box">
        <div class="tl-info-label">Durée</div>
        <div class="tl-info-value"><%= @training.duration %> min</div>
      </div>
      <div class="tl-info-box">
        <div class="tl-info-label">Joueurs</div>
        <div class="tl-info-value"><%= @training.team_size %></div>
      </div>
      <div class="tl-info-box">
        <div class="tl-info-label">Intensité</div>
        <div class="tl-info-value"><%= @training.intensity %>/10</div>
      </div>
    </div>

    <%# ── Mise en place ──────────────────────────────────────────── %>
    <div class="tl-section">
      <div class="tl-section-title">
        <i class="fa-solid fa-list-ol"></i> Mise en place détaillée
      </div>
      <div class="tl-section-content">
        <% if @training.content.present? %>
          <%= markdown(@training.content) %>
        <% else %>
          <p style="font-style: italic; opacity: 0.55;">Aucun contenu disponible pour cet exercice.</p>
        <% end %>
      </div>
    </div>

    <%# ── Le Conseil du Maestro ──────────────────────────────────── %>
    <div class="tl-section tl-maestro">
      <div class="tl-section-title">
        <i class="fa-solid fa-star"></i> Le Conseil du Maestro
      </div>
      <div class="tl-section-content">
        <% if @training.maestro_conseil.present? %>
          <%= markdown("_\"#{@training.maestro_conseil}\"_") %>
        <% else %>
          <p>Ce conseil sera bientôt affiché ici.</p>
        <% end %>
      </div>
    </div>

  </div>
<% end %>
