<% content_for :hide_navbar, true %>

<div class="signup-scene">
  <div class="signup-orb"></div>

  <%= link_to root_path, class: "signup-back" do %>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M19 12H5M12 5l-7 7 7 7"/>
    </svg>
    Back
  <% end %>

  <div class="signup-card">

    <div class="signup-header">
      <span class="signup-eyebrow">Powered by Le Wagon</span>
      <h1 class="signup-title">Padel<br>Maestro</h1>
      <p class="signup-subtitle">Create your account</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "signup-form" }) do |f| %>

      <% if resource.errors.any? %>
        <div class="signup-errors">
          <% resource.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-grid">

        <!-- Credentials -->
        <div class="form-section">
          <span class="form-section-label">Credentials</span>

          <div class="field-wrap" style="animation-delay:0.10s">
            <div class="signup-field">
              <label>Email <span class="required">*</span></label>
              <%= f.email_field :email, class: "signup-input", placeholder: "you@example.com", autocomplete: "email" %>
            </div>
          </div>

          <div class="field-wrap" style="animation-delay:0.18s">
            <div class="signup-field">
              <label>Password <span class="required">*</span></label>
              <%= f.password_field :password, class: "signup-input", placeholder: "••••••••", autocomplete: "new-password" %>
              <% if @minimum_password_length %>
                <span class="hint"><%= @minimum_password_length %> characters minimum</span>
              <% end %>
            </div>
          </div>

          <div class="field-wrap" style="animation-delay:0.26s">
            <div class="signup-field">
              <label>Confirm password <span class="required">*</span></label>
              <%= f.password_field :password_confirmation, class: "signup-input", placeholder: "••••••••", autocomplete: "new-password" %>
            </div>
          </div>
        </div>

        <!-- Player profile -->
        <div class="form-section">
          <span class="form-section-label">Player profile</span>

          <div class="field-row">
            <div class="field-wrap" style="animation-delay:0.34s">
              <div class="signup-field">
                <label>Username <span class="required">*</span></label>
                <%= f.text_field :username, class: "signup-input", placeholder: "John" %>
              </div>
            </div>
            <div class="field-wrap" style="animation-delay:0.38s">
              <div class="signup-field">
                <label>Age <span class="required">*</span></label>
                <%= f.number_field :age, class: "signup-input", placeholder: "28", min: 1 %>
              </div>
            </div>
          </div>

          <div class="field-wrap hand-wrap" style="animation-delay:0.42s">
            <label class="signup-label">Gender</label>
            <div class="hand-options">
              <% ["Male", "Female", "Other"].each do |option| %>
                <label class="hand-option">
                  <%= f.radio_button :gender, option.downcase %>
                  <span><%= option %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div class="field-row">
            <div class="field-wrap" style="animation-delay:0.46s">
              <div class="signup-field">
                <label>Weight (kg) <span class="required">*</span></label>
                <%= f.number_field :weight, class: "signup-input", placeholder: "75", min: 1 %>
              </div>
            </div>
            <div class="field-wrap" style="animation-delay:0.50s">
              <div class="signup-field">
                <label>Height (cm) <span class="required">*</span></label>
                <%= f.number_field :height, class: "signup-input", placeholder: "180", min: 1 %>
              </div>
            </div>
          </div>
        </div>

        <!-- Padel stats -->
        <div class="form-section">
          <span class="form-section-label">Padel stats</span>

          <div class="field-row">
            <div class="field-wrap" style="animation-delay:0.54s">
              <div class="signup-field">
                <label>Level (1–7) <span class="required">*</span></label>
                <%= f.number_field :padel_level, class: "signup-input", placeholder: "3", min: 1, max: 7, step: 0.5 %>
              </div>
            </div>
          </div>

          <div class="field-wrap hand-wrap" style="animation-delay:0.58s">
            <label class="signup-label">Playing hand <span class="required">*</span></label>
            <div class="hand-options">
              <% ["Left", "Right", "Both"].each do |option| %>
                <label class="hand-option">
                  <%= f.radio_button :hand_position, option %>
                  <span><%= option %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>

      </div>

      <div class="field-wrap" style="animation-delay:0.60s">
        <button type="submit" class="signup-submit">Create account</button>
      </div>

    <% end %>

    <div class="signup-links">
      Already have an account?
      <%= link_to "Log in", root_path, class: "signup-link" %>
    </div>

  </div>
</div>
